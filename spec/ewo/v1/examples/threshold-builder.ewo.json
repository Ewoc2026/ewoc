{
  "format": "ewo",
  "version": "1.3",
  "title": "Threshold Builder",
  "description": "Sweet-spot and threshold intervals to build sustained power capacity.",
  "difficulty": "hard",
  "tags": ["threshold", "sweet-spot", "structured"],
  "segments": [
    {
      "id": "warmup",
      "type": "steady",
      "duration_sec": 600,
      "target": { "metric": "ftp_percent", "value": 0.55 },
      "cadence": { "low": 85, "high": 95 }
    },
    {
      "id": "sweet-spot-1",
      "type": "steady",
      "duration_sec": 600,
      "target": { "metric": "ftp_percent", "value": 0.88 },
      "cadence": { "low": 90, "high": 100 }
    },
    {
      "id": "recovery-1",
      "type": "steady",
      "duration_sec": 300,
      "target": { "metric": "ftp_percent", "value": 0.50 }
    },
    {
      "id": "threshold-ramp",
      "type": "ramp",
      "duration_sec": 300,
      "from_target": { "metric": "ftp_percent", "value": 0.75 },
      "to_target": { "metric": "ftp_percent", "value": 1.00 }
    },
    {
      "id": "threshold-hold",
      "type": "steady",
      "duration_sec": 600,
      "target": { "metric": "ftp_percent", "value": 1.00 },
      "cadence": { "low": 88, "high": 95 }
    },
    {
      "id": "cooldown",
      "type": "steady",
      "duration_sec": 600,
      "target": { "metric": "ftp_percent", "value": 0.50 },
      "cadence": { "low": 80, "high": 90 }
    }
  ]
}
