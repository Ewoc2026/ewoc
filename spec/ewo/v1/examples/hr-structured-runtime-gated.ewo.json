{
  "format": "ewo",
  "version": "1.0",
  "title": "Heart-Rate Structured Runtime-Gated",
  "description": "Canonical heart-rate fixture that is valid for parsing but not yet executable in the Android runner.",
  "control": {
    "initial_power_watts": 120,
    "min_power_watts": 90,
    "max_power_watts": 240,
    "signal_loss_power_watts": 100,
    "hr_upper_cap_bpm": 160
  },
  "messages": [
    {
      "kind": "intro",
      "when": "start",
      "text": {
        "default": "Use heart rate as the guide rail for the work block."
      }
    }
  ],
  "segments": [
    {
      "id": "warmup",
      "type": "steady",
      "duration_sec": 300,
      "target": {
        "metric": "power",
        "value": 130
      }
    },
    {
      "id": "hr_block",
      "type": "repeat",
      "count": 2,
      "segments": [
        {
          "id": "hr_hold",
          "type": "steady",
          "duration_sec": 120,
          "target": {
            "metric": "heart_rate",
            "range": {
              "low": 145,
              "high": 155
            }
          },
          "messages": [
            {
              "kind": "instruction",
              "when": "start",
              "text": {
                "default": "Stay inside the band without chasing spikes.",
                "translations": {
                  "fi": "Pysy alueella ilman että jahtaat piikkejä."
                }
              }
            }
          ]
        },
        {
          "id": "float",
          "type": "steady",
          "duration_sec": 60,
          "target": {
            "metric": "power",
            "value": 140
          }
        }
      ]
    }
  ]
}
