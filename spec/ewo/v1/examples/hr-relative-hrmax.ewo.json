{
  "format": "ewo",
  "version": "1.4",
  "title": "HR Relative — HR Max Zones",
  "description": "Steady-state endurance ride using heart_rate_relative targets referenced to HR max.",
  "control": {
    "initial_power_watts": 110,
    "min_power_watts": 90,
    "max_power_watts": 220,
    "signal_loss_power_watts": 100,
    "hr_upper_cap_bpm": 175
  },
  "segments": [
    {
      "id": "warmup",
      "type": "steady",
      "duration_sec": 600,
      "target": {
        "metric": "power",
        "value": 120
      }
    },
    {
      "id": "zone2",
      "type": "steady",
      "duration_sec": 1200,
      "target": {
        "metric": "heart_rate_relative",
        "reference": "hr_max",
        "range": {
          "low": 0.60,
          "high": 0.70
        }
      }
    },
    {
      "id": "tempo",
      "type": "steady",
      "duration_sec": 900,
      "target": {
        "metric": "heart_rate_relative",
        "reference": "hr_max",
        "range": {
          "low": 0.72,
          "high": 0.80
        }
      }
    },
    {
      "id": "cooldown",
      "type": "steady",
      "duration_sec": 300,
      "target": {
        "metric": "power",
        "value": 100
      }
    }
  ]
}
