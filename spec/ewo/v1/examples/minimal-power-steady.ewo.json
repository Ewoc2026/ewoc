{
  "format": "ewo",
  "version": "1.0",
  "title": "Minimal Power Steady",
  "description": "Smallest useful power-only fixture for parser and editor smoke checks.",
  "messages": [
    {
      "kind": "intro",
      "when": "start",
      "text": {
        "default": "Settle into a smooth aerobic effort."
      }
    }
  ],
  "segments": [
    {
      "id": "warmup",
      "type": "steady",
      "duration_sec": 600,
      "target": {
        "metric": "power",
        "value": 150
      },
      "messages": [
        {
          "kind": "instruction",
          "when": "start",
          "text": {
            "default": "Hold a calm endurance pace."
          }
        }
      ]
    }
  ]
}
